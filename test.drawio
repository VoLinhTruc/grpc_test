                <mxCell id="69" value="" style="endArrow=classic;html=1;rounded=0;exitX=0.25;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;endFill=1;" edge="1" parent="1" source="3" target="67">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
                        <mxPoint x="3955" y="80" as="sourcePoint"/>
                        <mxPoint x="3970" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="70" value="1. The enviroment provides:&lt;br&gt;1.1 the ability to Run the&amp;nbsp;&lt;span style=&quot;font-family: &amp;#34;helvetica&amp;#34;&quot;&gt;SW under test&lt;/span&gt;&lt;br&gt;1.2 the interface to interfact (control, monitor the&amp;nbsp;&lt;span style=&quot;font-family: &amp;#34;helvetica&amp;#34;&quot;&gt;SW under test status aka variable)&lt;br&gt;1.3 provide the tool to log, analyze,... the running result&lt;br&gt;&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
                    <mxGeometry x="4740" y="-190" width="340" height="90" as="geometry"/>
                </mxCell>

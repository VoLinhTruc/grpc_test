        <!-- Left Column: FMU Approach -->
        <mxCell id="leftBox" value="Current VnV Approach\nFMU (monolithic)" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="560" height="60" as="geometry"/>

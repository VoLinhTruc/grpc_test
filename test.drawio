                <mxCell id="27" value="SDV approach&lt;br&gt;Container (Micro services)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=30;" vertex="1" parent="1">
                    <mxGeometry x="3770" y="420" width="390" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="28" value="&lt;b&gt;Pros:&lt;/b&gt;&lt;br&gt;- Standadize (FMI)&lt;br&gt;- Multiple tools support:&amp;nbsp;Simulink, Modelica, OpenModelica, Dymola, FMPy, dSPACE, Vector, ETAS&lt;br&gt;&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;br&gt;- High cost&lt;br&gt;- Not support CI/CD/CT natively&lt;br&gt;- Hard to expand&lt;br&gt;- Hard to achieving seamless communication between virtual ECUs and embedded ECUs&lt;br&gt;- &lt;b&gt;BlackBox&lt;/b&gt;, Very hard to debug" style="rounded=0;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
                    <mxGeometry x="4340" y="-750" width="240" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="29" value="&lt;b&gt;Pros:&lt;/b&gt;&lt;br&gt;- Low cost&lt;br&gt;- Strong CI/CD/CT&amp;nbsp;support&lt;br&gt;- Strong expand ability&lt;br&gt;- Be able to achieving seamless communication between virtual ECUs and embedded ECUs&lt;br&gt;- Possible to test multiple vECU&lt;br&gt;- &lt;b&gt;WhiteBox&lt;/b&gt;, Easy to debugging and monitoring even monitoring multiple vECU at a time&lt;br&gt;- &lt;b&gt;Possible to integrate FMU&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Cons:&lt;/b&gt;&lt;br&gt;- Not fully Standadize&amp;nbsp;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
                    <mxGeometry x="4300" y="250" width="240" height="230" as="geometry"/>
                </mxCell>

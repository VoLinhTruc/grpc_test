  <diagram id="clean-vnv" name="Page-1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="VnV Approaches Comparison" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=28;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="700" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="leftBox" value="Current VnV Approach&lt;br/&gt;FMU (monolithic)" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="560" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="leftFlow" value="Flow" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="560" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="leftFlowText" value="SW under test → VnV_Config → config.yaml → FMU Build → CoSym Environment" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="leftFlow">
          <mxGeometry x="10" y="10" width="540" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="leftProsCons" value="Pros:&lt;br/&gt;- Standardized (FMI)&lt;br/&gt;- Broad tool support (Simulink, Modelica, Dymola, FMPy, dSPACE, Vector, ETAS)&lt;br/&gt;&lt;br/&gt;Cons:&lt;br/&gt;- High cost&lt;br/&gt;- Weak CI/CD support&lt;br/&gt;- Hard to expand&lt;br/&gt;- Hard to debug (black-box)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="560" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="rightBox" value="SDV Approach&lt;br/&gt;Container (Microservices)" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="780" y="90" width="560" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="rightFlow" value="Flow" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="780" y="170" width="560" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="rightFlowText" value="SW under test → Protobuf + gRPC services → Docker image / devContainer → vECU container → Tester interface + Scheduler → Orchestrator&lt;br/&gt;&lt;br/&gt;All components communicate via gRPC on the same network." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="rightFlow">
          <mxGeometry x="10" y="10" width="540" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="rightProsCons" value="Pros:&lt;br/&gt;- Low cost&lt;br/&gt;- Strong CI/CD/CT support&lt;br/&gt;- Highly scalable&lt;br/&gt;- White-box debugging&lt;br/&gt;- Can integrate FMU&lt;br/&gt;&lt;br/&gt;Cons:&lt;br/&gt;- Not fully standardized" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="780" y="410" width="560" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="roadmap" value="Roadmap (Stages)" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=16;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1280" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="stageText" value="1) Build simple SW + proto + gRPC client&lt;br/&gt;2) Replace with real SW (e.g., HONDA PKlib)&lt;br/&gt;3) Automate build + create testing app with auto-populated UI from proto&lt;br/&gt;4) Auto-test container with predefined actions/expectations&lt;br/&gt;5) Compose to manage containers&lt;br/&gt;6) Refine project structure&lt;br/&gt;7) AI guidance for auto-tests on PR/Push" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="60" y="670" width="1280" height="180" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

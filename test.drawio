        <mxCell id="rightFlow" value="Flow" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="780" y="170" width="560" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="rightFlowText" value="SW under test → Protobuf + gRPC services → Docker image / devContainer → vECU container → Tester interface + Scheduler → Orchestrator\n\nAll components communicate via gRPC on the same network." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="rightFlow">
          <mxGeometry x="10" y="10" width="540" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="rightProsCons" value="Pros:\n- Low cost\n- Strong CI/CD/CT support\n- Highly scalable\n- White-box debugging\n- Can integrate FMU\n\nCons:\n- Not fully standardized" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="780" y="410" width="560" height="170" as="geometry"/>
        </mxCell>

        <!-- Roadmap -->
        <mxCell id="roadmap" value="Roadmap (Stages)" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=16;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1280" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="stageText" value="1) Build simple SW + proto + gRPC client\n2) Replace with real SW (e.g., HONDA PKlib)\n3) Automate build + create testing app with auto-populated UI from proto\n4) Auto-test container with predefined actions/expectations\n5) Compose to manage containers\n6) Refine project structure\n7) AI guidance for auto-tests on PR/Push" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=12;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="1">

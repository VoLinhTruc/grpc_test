                <mxCell id="26" value="Current VnV Approach&lt;br&gt;FMU (monolithic)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=30;" vertex="1" parent="1">
                    <mxGeometry x="3840" y="-690" width="330" height="90" as="geometry"/>
